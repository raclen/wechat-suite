# ============================================
# WeChat Daily - 配置文件
# ============================================
# 复制本文件为 config.yaml，然后填入你的 API Keys

# ---------- AI 设置 ----------
# 支持: deepseek / newapi / qwen / openai
ai:
  provider: "deepseek"
  api_key: ""                         # 在 platform.deepseek.com 获取
  model: "deepseek-chat"              # deepseek-chat (V3) 性价比最高
  max_tokens: 4096
  # base_url: ""                      # 留空则自动使用对应平台地址
  #
  # === 其他平台配置示例 ===
  #
  # 通义千问:
  #   provider: "qwen"
  #   api_key: "YOUR_QWEN_API_KEY"
  #   model: "qwen-plus"
  #
  # NewAPI:
  #   provider: "newapi"
  #   api_key: "YOUR_NEWAPI_API_KEY"
  #   model: "gpt-4o-mini"             # 改成你在 NewAPI 里配置的模型名
  #   base_url: "http://127.0.0.1:3000/v1"
  #
  # OpenAI:
  #   provider: "openai"
  #   api_key: "YOUR_OPENAI_API_KEY"
  #   model: "gpt-4o"

# ---------- Notion API ----------
notion:
  api_key: ""                         # 在 notion.so/my-integrations 创建
  daily_summary_db_id: ""             # 运行 --setup 后填入
  todo_tasks_db_id: ""                # 运行 --setup 后填入

# ---------- 微信数据 ----------
wechat:
  # WeChatDataAnalysis 后端 API 地址（用于自动导出）
  tool_api_url: "http://127.0.0.1:10392"
  # WeChatDataAnalysis 导出文件的目录
  export_dir: "export"
  # 你自己的微信昵称
  my_nickname: ""
  # 你的微信 wxid（可留空，自动识别）
  my_wxid: ""
  # 排除的群聊（不需要分析的群）
  excluded_groups:
    # - "某某通知群"
    # - "快递取件群"
  # 重要群聊（总结时优先展示）
  important_groups:
    # - "工作群"
    # - "项目讨论"

# ---------- 处理设置 ----------
processing:
  max_messages_per_chat: 200          # 每个对话最多取多少条消息
  ignored_msg_types:                  # 跳过的消息类型
    - "system"
    - "voip"
    - "emoji"
  min_messages_threshold: 3           # 消息少于此数的对话会被跳过
  auto_catchup_days: 7                # 自动补跑最近 N 天内漏掉的日期（0 = 关闭）

# ---------- 日志 ----------
logging:
  level: "INFO"
  file: "logs/run.log"

# ---------- 指定会话总结 ----------
# 这些参数都可以写到配置里，运行时就不用写很长的命令。
# run_group_daily.sh / run_group_daily_pipeline.py / summarize_export_chat.py
# 会优先读取 chat_summary；没有配置时兼容旧的 group_daily。
#
# 最短运行命令：
#   ./run_group_daily.sh config.local.yaml
#
# mode:
#   group   = 群聊日报
#   private = 微信个人对话总结
#   speaker = 指定群聊中某个人的发言总结
#
# 时间段可选：
#   start_time/end_time 留空 = 总结 date 当天全部消息
#   "09:00"             = date 当天 09:00
#   "23:30" 到 "01:00" 不能表示跨天；跨天请写完整日期时间
#   "2026-06-23 23:30" = 指定日期时间，可跨天
#
# 当前启用的配置：群聊日报 + 同时导出 Figma 风格 PNG
chat_summary:
  chat_name: "Walk AI Coding"         # 群名、联系人显示名、备注名或 wxid
  date: "today"                       # YYYY-MM-DD 或 today
  mode: "group"
  start_time: ""                       # 可选: "09:00" 或 "2026-06-23 09:00"
  end_time: ""                         # 可选: "18:30" 或 "2026-06-23 18:30"
  speaker: ""                         # mode=speaker 时填写 sender 名称或 wxid
  render_png: false                   # true 时额外生成 Figma 风格 PNG
  output_dir: "group_daily_exports"
  input_json: "markdown_exports/Walk_AI_Coding-export.json"
  decrypt_repo: "../wechat-decrypt"
  max_messages: 260
  # png_output: "group_daily_exports/custom-name.png"  # 可选；不填则与 Markdown 同名

# ---------- 配置示例：微信个人对话总结 ----------
# 把上面的 chat_summary 替换成下面这段即可。
# chat_summary:
#   chat_name: "某联系人"                         # 联系人显示名、备注名或 wxid
#   date: "2026-06-23"
#   mode: "private"
#   start_time: "09:00"
#   end_time: "18:30"
#   render_png: true
#   output_dir: "group_daily_exports"
#   input_json: "markdown_exports/某联系人-export.json"
#   decrypt_repo: "../wechat-decrypt"
#   max_messages: 260

# ---------- 配置示例：群聊里某个人发言总结 ----------
# speaker 必须和导出 JSON 里的 messages[].sender 一致。
# 如果群成员没有昵称，可能会是 wxid_xxx；可以先打开导出的 JSON 查 sender。
# chat_summary:
#   chat_name: "Walk AI Coding"
#   date: "2026-06-23"
#   mode: "speaker"
#   speaker: "Walk-gpt"
#   start_time: "2026-06-23 23:30"     # 跨天时间段要写完整日期时间
#   end_time: "2026-06-24 02:00"
#   render_png: true
#   output_dir: "group_daily_exports"
#   input_json: "markdown_exports/Walk_AI_Coding-export.json"
#   decrypt_repo: "../wechat-decrypt"
#   max_messages: 260
